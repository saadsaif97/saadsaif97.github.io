---
/**
 * Firebase-powered Reviews with Google Sign-in
 *
 * SETUP (one-time):
 * 1. Go to https://console.firebase.google.com → create a project
 * 2. Project settings → "Your apps" → add a Web app → copy the config into src/config.ts FIREBASE object
 * 3. Authentication → Sign-in method → enable "Google"
 * 4. Authentication → Settings → Authorized domains → add "ecomwonk.com"
 * 5. Firestore Database → Create database (start in production mode)
 * 6. Firestore → Rules → paste the rules below and publish:
 *
 *   rules_version = '2';
 *   service cloud.firestore {
 *     match /databases/{database}/documents {
 *       match /reviews/{postId}/entries/{entryId} {
 *         allow read: if true;
 *         allow create: if request.auth != null
 *           && request.resource.data.uid == request.auth.uid
 *           && request.resource.data.rating is int
 *           && request.resource.data.rating >= 1
 *           && request.resource.data.rating <= 5
 *           && request.resource.data.body is string
 *           && request.resource.data.body.size() <= 1000;
 *         allow delete: if request.auth != null
 *           && resource.data.uid == request.auth.uid;
 *       }
 *     }
 *   }
 */

import { FIREBASE } from "@/config";
---

<section id="reviews-section" class="mt-10 p-0" data-firebase={JSON.stringify(FIREBASE)}>
  <h2 id="reviews" class="mb-1 text-lg font-semibold text-foreground">Reviews</h2>

  <!-- Average rating summary -->
  <div id="reviews-summary" class="mb-6 flex items-center gap-2 text-sm text-foreground/60">
    <span id="avg-stars" class="text-xl text-yellow-400">☆☆☆☆☆</span>
    <span id="avg-label">No reviews yet</span>
  </div>

  <!-- Auth bar -->
  <div id="auth-bar" class="mb-6">
    <button
      id="btn-signin"
      class="flex items-center gap-2 rounded-lg border border-foreground/20 bg-background px-4 py-2 text-sm font-medium text-foreground shadow-sm hover:bg-foreground/5 transition-colors"
    >
      <svg width="18" height="18" viewBox="0 0 48 48" xmlns="http://www.w3.org/2000/svg">
        <path fill="#EA4335" d="M24 9.5c3.54 0 6.71 1.22 9.21 3.6l6.85-6.85C35.9 2.38 30.47 0 24 0 14.62 0 6.51 5.38 2.56 13.22l7.98 6.19C12.43 13.72 17.74 9.5 24 9.5z"/>
        <path fill="#4285F4" d="M46.98 24.55c0-1.57-.15-3.09-.38-4.55H24v9.02h12.94c-.58 2.96-2.26 5.48-4.78 7.18l7.73 6c4.51-4.18 7.09-10.36 7.09-17.65z"/>
        <path fill="#FBBC05" d="M10.53 28.59c-.48-1.45-.76-2.99-.76-4.59s.27-3.14.76-4.59l-7.98-6.19C.92 16.46 0 20.12 0 24c0 3.88.92 7.54 2.56 10.78l7.97-6.19z"/>
        <path fill="#34A853" d="M24 48c6.48 0 11.93-2.13 15.89-5.81l-7.73-6c-2.18 1.48-4.97 2.31-8.16 2.31-6.26 0-11.57-4.22-13.47-9.91l-7.98 6.19C6.51 42.62 14.62 48 24 48z"/>
        <path fill="none" d="M0 0h48v48H0z"/>
      </svg>
      Sign in with Google to leave a review
    </button>
  </div>

  <!-- Signed-in user bar (hidden until logged in) -->
  <div id="user-bar" class="mb-6 hidden flex-wrap items-center gap-3">
    <img id="user-photo" src="" alt="" width="32" height="32" class="rounded-full" />
    <span id="user-name" class="text-sm font-medium text-foreground"></span>
    <button id="btn-signout" class="text-xs text-foreground/50 underline hover:text-foreground">Sign out</button>
  </div>

  <!-- Write review form (hidden until logged in) -->
  <form
    id="review-form"
    class="mb-8 hidden rounded-xl border border-foreground/10 bg-foreground/[0.03] p-4"
  >
    <p class="mb-2 text-sm font-medium text-foreground">Your rating</p>
    <div id="star-picker" class="mb-3 flex gap-1 text-2xl" role="group" aria-label="Rating">
      {[1, 2, 3, 4, 5].map(n => (
        <button
          type="button"
          data-star={n}
          class="star-btn leading-none text-foreground/20 transition-colors hover:text-yellow-400 focus:outline-none"
          aria-label={`${n} star${n > 1 ? "s" : ""}`}
        >★</button>
      ))}
    </div>
    <input type="hidden" id="selected-rating" value="0" />

    <textarea
      id="review-body"
      rows="3"
      maxlength="1000"
      placeholder="Share your thoughts about this post… (optional)"
      class="mb-3 w-full resize-none rounded-lg border border-foreground/20 bg-background px-3 py-2 text-sm text-foreground placeholder:text-foreground/30 focus:border-accent focus:outline-none"
    ></textarea>

    <div class="flex items-center gap-3">
      <button
        type="submit"
        id="btn-submit"
        class="rounded-lg bg-accent px-4 py-1.5 text-sm font-semibold text-white disabled:opacity-50 transition-opacity"
        disabled
      >Submit Review</button>
      <span id="form-msg" class="text-xs text-foreground/50"></span>
    </div>
  </form>

  <!-- Reviews list -->
  <div id="reviews-list" class="space-y-4"></div>
</section>

<script is:inline data-astro-rerun>
(function () {
  const section = document.getElementById("reviews-section");
  if (!section) return;

  const firebaseConfig = JSON.parse(section.dataset.firebase || "{}");
  const postId = location.pathname.replace(/\//g, "_").replace(/^_|_$/g, "") || "home";

  // ── Lazy-load Firebase SDKs ────────────────────────────────────────────────
  function loadScript(src) {
    return new Promise((resolve, reject) => {
      if (document.querySelector(`script[src="${src}"]`)) { resolve(); return; }
      const s = document.createElement("script");
      s.src = src;
      s.onload = resolve;
      s.onerror = reject;
      document.head.appendChild(s);
    });
  }

  async function init() {
    await loadScript("https://www.gstatic.com/firebasejs/10.12.2/firebase-app-compat.js");
    await loadScript("https://www.gstatic.com/firebasejs/10.12.2/firebase-auth-compat.js");
    await loadScript("https://www.gstatic.com/firebasejs/10.12.2/firebase-firestore-compat.js");

    if (!firebase.apps.length) firebase.initializeApp(firebaseConfig);
    const auth = firebase.auth();
    const db = firebase.firestore();
    const entriesRef = db.collection("reviews").doc(postId).collection("entries");

    // ── Elements ────────────────────────────────────────────────────────────
    const btnSignin   = document.getElementById("btn-signin");
    const btnSignout  = document.getElementById("btn-signout");
    const authBar     = document.getElementById("auth-bar");
    const userBar     = document.getElementById("user-bar");
    const userPhoto   = document.getElementById("user-photo");
    const userName    = document.getElementById("user-name");
    const reviewForm  = document.getElementById("review-form");
    const starPicker  = document.getElementById("star-picker");
    const starBtns    = starPicker.querySelectorAll(".star-btn");
    const ratingInput = document.getElementById("selected-rating");
    const bodyInput   = document.getElementById("review-body");
    const btnSubmit   = document.getElementById("btn-submit");
    const formMsg     = document.getElementById("form-msg");
    const reviewsList = document.getElementById("reviews-list");
    const avgStars    = document.getElementById("avg-stars");
    const avgLabel    = document.getElementById("avg-label");

    // ── Star picker ─────────────────────────────────────────────────────────
    let hoveredRating = 0;
    let selectedRating = 0;

    function paintStars(upTo) {
      starBtns.forEach(btn => {
        const n = parseInt(btn.dataset.star);
        btn.classList.toggle("text-yellow-400", n <= upTo);
        btn.classList.toggle("text-foreground/20", n > upTo);
      });
    }

    starBtns.forEach(btn => {
      const n = parseInt(btn.dataset.star);
      btn.addEventListener("mouseenter", () => { hoveredRating = n; paintStars(n); });
      btn.addEventListener("mouseleave", () => { hoveredRating = 0; paintStars(selectedRating); });
      btn.addEventListener("click", () => {
        selectedRating = n;
        ratingInput.value = n;
        paintStars(n);
        btnSubmit.disabled = false;
      });
    });

    // ── Auth ────────────────────────────────────────────────────────────────
    btnSignin.addEventListener("click", () => {
      const provider = new firebase.auth.GoogleAuthProvider();
      auth.signInWithPopup(provider).catch(err => console.error("Sign-in error:", err));
    });

    btnSignout.addEventListener("click", () => auth.signOut());

    auth.onAuthStateChanged(user => {
      if (user) {
        authBar.classList.add("hidden");
        userBar.classList.remove("hidden");
        userBar.classList.add("flex");
        userPhoto.src = user.photoURL || "";
        userName.textContent = user.displayName || user.email;
        reviewForm.classList.remove("hidden");
      } else {
        authBar.classList.remove("hidden");
        userBar.classList.add("hidden");
        userBar.classList.remove("flex");
        reviewForm.classList.add("hidden");
      }
    });

    // ── Submit review ────────────────────────────────────────────────────────
    reviewForm.addEventListener("submit", async e => {
      e.preventDefault();
      const user = auth.currentUser;
      if (!user) return;
      const rating = parseInt(ratingInput.value);
      if (!rating) { formMsg.textContent = "Please pick a star rating."; return; }

      btnSubmit.disabled = true;
      formMsg.textContent = "Saving…";

      try {
        // One review per user: use uid as document id
        await entriesRef.doc(user.uid).set({
          uid: user.uid,
          name: user.displayName || "Anonymous",
          photoURL: user.photoURL || "",
          rating,
          body: bodyInput.value.trim().slice(0, 1000),
          createdAt: firebase.firestore.FieldValue.serverTimestamp(),
        });
        formMsg.textContent = "Review saved!";
        setTimeout(() => { formMsg.textContent = ""; }, 3000);
        // Reset form
        selectedRating = 0;
        ratingInput.value = 0;
        paintStars(0);
        bodyInput.value = "";
        btnSubmit.disabled = true;
      } catch (err) {
        console.error(err);
        formMsg.textContent = "Error saving review. Please try again.";
        btnSubmit.disabled = false;
      }
    });

    // ── Render reviews list ──────────────────────────────────────────────────
    function starsHtml(rating) {
      return Array.from({ length: 5 }, (_, i) =>
        `<span class="${i < rating ? "text-yellow-400" : "text-foreground/20"}">★</span>`
      ).join("");
    }

    entriesRef.orderBy("createdAt", "desc").onSnapshot(snapshot => {
      const docs = snapshot.docs.map(d => ({ id: d.id, ...d.data() }));

      // Update summary
      if (docs.length === 0) {
        avgStars.innerHTML = "☆☆☆☆☆";
        avgLabel.textContent = "No reviews yet, be the first!";
      } else {
        const avg = docs.reduce((s, d) => s + (d.rating || 0), 0) / docs.length;
        const rounded = Math.round(avg * 10) / 10;
        avgStars.innerHTML = starsHtml(Math.round(avg));
        avgLabel.textContent = `${rounded} out of 5 · ${docs.length} review${docs.length !== 1 ? "s" : ""}`;
      }

      // Render list
      reviewsList.innerHTML = docs.map(d => {
        const date = d.createdAt?.toDate?.()
          ? new Date(d.createdAt.toDate()).toLocaleDateString("en-US", { year: "numeric", month: "short", day: "numeric" })
          : "";
        const isMine = auth.currentUser?.uid === d.uid;
        return `
          <div class="flex gap-3 rounded-xl border border-foreground/10 p-4" data-entry-id="${d.id}">
            ${d.photoURL ? `<img src="${d.photoURL}" alt="" width="36" height="36" class="flex-none rounded-full" referrerpolicy="no-referrer" />` : `<div class="flex h-9 w-9 flex-none items-center justify-center rounded-full bg-accent/20 text-sm font-bold text-accent">${(d.name || "?")[0].toUpperCase()}</div>`}
            <div class="min-w-0 flex-1">
              <div class="flex flex-wrap items-center gap-2">
                <span class="text-sm font-semibold text-foreground">${d.name || "Anonymous"}</span>
                <span class="text-base leading-none">${starsHtml(d.rating || 0)}</span>
                ${date ? `<span class="text-xs text-foreground/40">${date}</span>` : ""}
                ${isMine ? `<button class="delete-btn ms-auto text-xs text-foreground/30 hover:text-red-500 transition-colors" data-id="${d.id}">Delete</button>` : ""}
              </div>
              ${d.body ? `<p class="mt-1 text-sm text-foreground/70 break-words">${d.body.replace(/</g, "&lt;").replace(/>/g, "&gt;")}</p>` : ""}
            </div>
          </div>`;
      }).join("");

      // Delete buttons
      reviewsList.querySelectorAll(".delete-btn").forEach(btn => {
        btn.addEventListener("click", async () => {
          const id = btn.dataset.id;
          if (!id || !confirm("Delete your review?")) return;
          try { await entriesRef.doc(id).delete(); } catch (err) { console.error(err); }
        });
      });
    });
  }

  // Run on page load and Astro view transitions
  init().catch(console.error);
  document.addEventListener("astro:after-swap", () => init().catch(console.error));
})();
</script>
