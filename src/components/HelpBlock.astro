---
// src/components/HelpBlock.astro
const whatsappNumber = "+923314002075";
const message = encodeURIComponent(
  "Hi Saad, I need help with my Shopify store."
);
const whatsappLink = `https://wa.me/${whatsappNumber}?text=${message}`;
---

<div
  class="my-12 rounded-2xl border border-green-500 bg-green-50 p-6 text-center shadow-md dark:bg-green-900/20"
>
  <img
    src="https://avatars.githubusercontent.com/u/58517683"
    alt="Saad Saif - Shopify Expert"
    class="mx-auto mb-4 h-20 w-20 rounded-full border-2 border-green-500 shadow-sm"
    loading="lazy"
  />

  <h3 class="mb-2 text-2xl font-semibold text-green-700 dark:text-green-300">
    Need Help With Your Shopify Store?
  </h3>

  <p class="mb-3 leading-relaxed text-gray-700 dark:text-gray-300">
    I'm a <span class="font-semibold">Shopify expert developer</span> working as a
    <span class="font-semibold">solo specialist</span>. When you reach out, you work
    <span class="font-semibold">directly with me</span>, no project managers or
    middlemen.
  </p>

  <p class="mb-3 leading-relaxed text-gray-700 dark:text-gray-300">
    If you need help with <span class="font-semibold">Shopify development</span>,
    improving <span class="font-semibold">conversions</span>, or increasing your
    store’s <span class="font-semibold">average order value</span>, feel free to
    message me on WhatsApp for a quick response.
  </p>

  <p class="mb-5 text-sm text-gray-600 dark:text-gray-400">
    We can work through <span class="font-semibold">Upwork</span> or you can pay
    securely via <span class="font-semibold">Payoneer</span>.
  </p>

  <a
    href={whatsappLink}
    target="_blank"
    rel="noopener noreferrer"
    class="inline-flex items-center gap-2 rounded-lg bg-green-600 px-6 py-2 font-medium text-white shadow transition-colors hover:bg-green-700"
  >
    <svg
      xmlns="http://www.w3.org/2000/svg"
      viewBox="0 0 32 32"
      class="h-5 w-5 fill-current"
    >
      <path
        d="M16.04 3C9.41 3 4.04 8.33 4.04 14.92c0 2.62.86 5.05 2.33 7.03L4 29l7.23-2.27a11.9 11.9 0 004.81.99c6.63 0 12-5.33 12-11.92S22.67 3 16.04 3zm0 21.78c-1.52 0-3-.38-4.32-1.09l-.31-.18-4.29 1.35 1.4-4.17-.2-.32a8.9 8.9 0 01-1.37-4.77c0-4.95 4.04-8.98 9.02-8.98s9.02 4.03 9.02 8.98-4.04 8.98-9.02 8.98zm4.95-6.73c-.27-.13-1.6-.79-1.84-.88-.25-.09-.43-.13-.61.13-.18.27-.7.88-.86 1.06-.16.18-.31.2-.58.07-.27-.13-1.13-.42-2.15-1.34-.79-.7-1.32-1.57-1.47-1.84-.16-.27-.02-.41.12-.54.12-.12.27-.31.4-.47.13-.16.18-.27.27-.45.09-.18.04-.34-.02-.47-.07-.13-.61-1.48-.84-2.02-.22-.53-.44-.46-.61-.47h-.52c-.18 0-.47.07-.72.34-.25.27-.95.93-.95 2.27 0 1.34.97 2.64 1.11 2.82.13.18 1.9 2.9 4.6 4.07.64.28 1.14.45 1.53.58.64.2 1.22.17 1.68.1.51-.08 1.6-.65 1.83-1.27.22-.63.22-1.17.16-1.27-.07-.11-.25-.18-.52-.31z"
      />
    </svg>

    Message me on WhatsApp
  </a>
</div>
