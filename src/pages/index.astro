---
import { getCollection } from "astro:content";
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import Socials from "@/components/Socials.astro";
import LinkButton from "@/components/LinkButton.astro";
import Card from "@/components/Card.astro";
import Hr from "@/components/Hr.astro";
import ServiceCard from "@/components/ServiceCard.astro";
import getSortedPosts from "@/utils/getSortedPosts";
import IconArrowRight from "@/assets/icons/IconArrowRight.svg";
import { SITE } from "@/config";
import { SOCIALS } from "@/constants";

const posts = await getCollection("blog");

const sortedPosts = getSortedPosts(posts);
const featuredPosts = sortedPosts.filter(({ data }) => data.featured);
const recentPosts = sortedPosts.filter(({ data }) => !data.featured);
---

<Layout>
  <Header />

  <main id="main-content" data-layout="index">
    
    <!-- TECHNICAL RETAINER -->
    <section id="retainer" class="pt-12 pb-6">

      <h2 class="mb-2 text-2xl font-semibold tracking-wide">
        Technical Retainer for Small Shopify Store Owners
      </h2>

      <p class="mb-4 max-w-2xl text-sm">
        Running a small Shopify store and constantly running into small technical issues, tweaks, or feature requests?
        Instead of hiring an agency or paying per-project rates, get a dedicated Shopify developer on retainer, available every month, ready when you need me.
      </p>

      <ul class="mb-6 space-y-2 max-w-2xl text-sm">
        <li>✓ Up to <strong>8 hours/month</strong> of Shopify development work</li>
        <li>✓ Theme fixes, custom tweaks, section edits, app integrations</li>
        <li>✓ Priority WhatsApp access, no ticket system, no agency delays</li>
        <li>✓ Monthly report of work done & suggestions for the next month</li>
        <li>✓ Cancel anytime, no long-term contracts</li>
      </ul>

      <p class="mb-6 max-w-2xl text-sm text-accent font-medium">
        Best for stores doing $5k–$50k/month that need a reliable developer without full-time costs.
      </p>

      <div class="flex flex-col gap-4 sm:flex-row">
        <a
          href="https://wa.me/+923314002075?text=Hi Saad, I'm interested in the Technical Retainer for my Shopify store"
          target="_blank"
          rel="noopener"
          class="inline-block rounded bg-green-600 px-6 py-3 text-center text-sm font-medium text-white transition hover:bg-green-700"
        >
          Inquire on WhatsApp
        </a>

        <a
          href="https://calendly.com/saadgfx97/shopify-theme-development"
          target="_blank"
          rel="noopener"
          class="inline-block rounded border border-muted px-6 py-3 text-center text-sm font-medium text-white transition"
        >
          Book a Quick Call
        </a>
      </div>

    </section>

    <Hr />
    
    <!-- FREE AUDIT OFFER -->
    <section id="free-audit" class="pt-12 pb-6">

      <h2 class="mb-2 text-2xl font-semibold tracking-wide">
        Free Shopify Store Audit, For Small Store Owners
      </h2>

      <p class="mb-4 max-w-2xl text-sm text-white">
        Not sure where your store is losing sales? I'll review your store and send you a
        short, actionable report covering UX, and quick-win fixes no strings attached.
      </p>

      <ul class="mb-6 space-y-2 max-w-2xl text-sm">
        <li>✓ Product page & cart UX review</li>
        <li>✓ Top 3 fixes to increase conversions</li>
        <li>✓ Delivered via WhatsApp or email within 48 hours</li>
      </ul>

      <a
        href="https://wa.me/+923314002075?text=Hi Saad, I'd like a free Shopify store audit"
        target="_blank"
        rel="noopener"
        class="inline-block rounded bg-green-600 px-6 py-3 text-center text-sm font-medium text-white transition hover:bg-green-700"
      >
        Request Your Free Audit
      </a>

    </section>

    <Hr />

    <!-- HERO -->
    <section id="hero" class="pt-8 pb-6">

      <h1 class="my-4 inline-block text-3xl font-bold sm:my-8 sm:text-4xl">
        Solo Shopify Developer
      </h1>

      <p class="max-w-2xl">
        I'm <strong>Saad Saif</strong>, a solo Shopify developer specializing in
        <strong>custom Shopify functionality, theme customization, and store performance optimization</strong>.
      </p>
      
      <p class="mt-4 *:max-w-2xl">
        When you message me, you directly chat with me, no middleman or non-technical manager between us.
      </p>

      <p class="mt-4 max-w-2xl">
        I help Shopify brands and agencies build faster, scalable storefronts by
        implementing custom features and removing reliance on heavy apps,
        improving <strong>conversion rate (CRO)</strong> and
        <strong>average order value (AOV)</strong>.
      </p>

      <p class="mt-4 max-w-2xl">
        I also share my Shopify development knowledge through
        <LinkButton
          class="underline decoration-dashed underline-offset-4 hover:text-accent"
          href="/courses"
        >
          courses
        </LinkButton>,
        <LinkButton
          class="underline decoration-dashed underline-offset-4 hover:text-accent"
          href="/posts"
        >
          blog posts
        </LinkButton>,
        and my
        <LinkButton
          class="underline decoration-dashed underline-offset-4 hover:text-accent"
          href="https://www.youtube.com/@saadsaif97/videos"
        >
          YouTube channel
        </LinkButton>
        where I teach advanced Shopify development.
      </p>

      <div class="mt-6 flex flex-col gap-4 sm:flex-row">
        <a
          href="https://calendly.com/saadgfx97/shopify-theme-development"
          target="_blank"
          rel="noopener"
          class="inline-block rounded border border-muted px-6 py-3 text-center text-sm font-medium text-white transition"
        >
          Get a Free Store Audit
        </a>

        <a
          href="https://wa.me/+923314002075?text=Hi Saad, I am interested in your Shopify services"
          target="_blank"
          rel="noopener"
          class="inline-block rounded bg-green-600 px-6 py-3 text-center text-sm font-medium text-white transition hover:bg-green-700"
        >
          Chat on WhatsApp
        </a>
      </div>

      {
        SOCIALS.length > 0 && (
          <div class="mt-6 flex flex-col sm:flex-row sm:items-center">
            <div class="me-2 mb-1 whitespace-nowrap sm:mb-0">
              Connect with me:
            </div>
            <Socials />
          </div>
        )
      }

    </section>

    <Hr />

    <!-- TRUST SECTION -->
    <section class="pt-12 pb-6">

      <h2 class="mb-6 text-2xl font-semibold tracking-wide">
        Trusted by Shopify Brands & Developers
      </h2>

      <ul class="space-y-2 max-w-2xl">
        <li>• 4+ years of Shopify development experience</li>
        <li>• Built custom functionality for multiple Shopify stores</li>
        <li>• 1600+ developers learning from my YouTube tutorials</li>
        <li>• 4000+ professionals following my Shopify insights on LinkedIn</li>
        <li>• Specialized in custom Shopify solutions without heavy apps</li>
      </ul>

    </section>

    <Hr />

    <!-- BLOG CONTENT -->

    {
      featuredPosts.length > 0 && (
        <>
          <section id="featured" class="pt-12 pb-6">
            <h2 class="text-2xl font-semibold tracking-wide">
              Featured Shopify Development Articles
            </h2>

            <ul>
              {featuredPosts.map(data => (
                <Card variant="h3" {...data} />
              ))}
            </ul>
          </section>

          {recentPosts.length > 0 && <Hr />}
        </>
      )
    }

    {
      recentPosts.length > 0 && (
        <section id="recent-posts" class="pt-12 pb-6">

          <h2 class="text-2xl font-semibold tracking-wide">
            Latest Shopify Development Insights
          </h2>

          <ul>
            {recentPosts.map(
              (data, index) =>
                index < SITE.postPerIndex && <Card variant="h3" {...data} />
            )}
          </ul>

        </section>
      )
    }

    <div class="my-8 text-center">
      <LinkButton href="/posts/">
        All Articles
        <IconArrowRight class="inline-block rtl:-rotate-180" />
      </LinkButton>
    </div>

  </main>

  <Footer />
</Layout>

<script>
  document.addEventListener("astro:page-load", () => {
    const indexLayout = (document.querySelector("#main-content") as HTMLElement)
      ?.dataset?.layout;

    if (indexLayout) {
      sessionStorage.setItem("backUrl", "/");
    }
  });
</script>
