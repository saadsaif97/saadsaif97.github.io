---
import { getCollection } from "astro:content";
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import LinkButton from "@/components/LinkButton.astro";
import Card from "@/components/Card.astro";
import Hr from "@/components/Hr.astro";
import getSortedPosts from "@/utils/getSortedPosts";
import IconArrowRight from "@/assets/icons/IconArrowRight.svg";
import { SITE } from "@/config";

const posts = await getCollection("blog");

const sortedPosts = getSortedPosts(posts);
const featuredPosts = sortedPosts.filter(({ data }) => data.featured);
const recentPosts = sortedPosts.filter(({ data }) => !data.featured);
---

<Layout>
  <Header />

  <main id="main-content" data-layout="index">

    <!-- HERO -->
    <section id="hero" class="pt-8 pb-6">

      <h1 class="my-4 inline-block text-3xl font-bold sm:my-8 sm:text-4xl">
        Solo Shopify Developer
      </h1>

      <p class="max-w-2xl">
        I'm <strong>Saad Saif</strong>, a solo Shopify developer. I help small Shopify store owners
        <strong>fix slow themes, remove costly apps, resolve technical issues, and add custom features</strong> without hiring an agency.
      </p>

      <p class="mt-4 max-w-2xl">
        You talk directly to me, not an account manager. No tickets, no delays.
      </p>

      <!-- <p class="mt-4 max-w-2xl">
        Helped a $15k/month store cut <strong>$180/month in app fees</strong> and improve page speed by <strong>40%</strong> with custom Liquid code.
      </p> -->

      <div class="mt-6 flex flex-col gap-4 sm:flex-row">
        <a
          href="https://wa.me/+923314002075?text=Hi Saad, I am interested in your Shopify services"
          target="_blank"
          rel="noopener"
          class="inline-block rounded bg-green-600 px-6 py-3 text-center text-sm font-medium text-white transition hover:bg-green-700"
        >
          Chat on WhatsApp
        </a>

        <a
          href="https://wa.me/+923314002075?text=Hi Saad, I'd like a free Shopify store audit"
          target="_blank"
          rel="noopener"
          class="inline-block rounded border border-muted px-6 py-3 text-center text-sm font-medium text-white transition hover:border-white"
        >
          Get a Free Store Audit
        </a>
      </div>

      <p class="mt-6 max-w-2xl text-sm text-foreground/60">
        I also share my Shopify development knowledge through
        <LinkButton
          class="underline decoration-dashed underline-offset-4 hover:text-accent"
          href="/courses"
        >
          courses
        </LinkButton>,
        <LinkButton
          class="underline decoration-dashed underline-offset-4 hover:text-accent"
          href="/posts"
        >
          blog posts
        </LinkButton>,
        and my
        <LinkButton
          class="underline decoration-dashed underline-offset-4 hover:text-accent"
          href="https://www.youtube.com/@saadsaif97/videos"
        >
          YouTube channel
        </LinkButton>.
      </p>

    </section>

    <Hr />

    <!-- TRUST SECTION -->
    <section class="pt-12 pb-6">

      <h2 class="mb-6 text-2xl font-semibold tracking-wide">
        Trusted by Shopify Brands & Developers
      </h2>

      <ul class="mb-8 space-y-2 max-w-2xl text-sm">
        <li>• 4+ years of Shopify development experience</li>
        <li>• Helped stores reduce monthly app costs by $100–$300/month</li>
        <li>• Worked with stores doing $5k–$50k/month</li>
        <li>• Direct WhatsApp access, response within 24 hours</li>
        <li>• Specialized in custom Shopify solutions without heavy apps</li>
      </ul>

      <!-- TESTIMONIALS — replace with real client quotes -->
      <div class="grid gap-4 sm:grid-cols-2 max-w-2xl">

        <blockquote class="rounded-lg border border-foreground/10 bg-foreground/[0.03] p-4 text-sm">
          <p class="mb-3 text-foreground/80">
            "Saad is very talented and has amazing communication skills. He was recording detailed videos with explanations. That was very helpful for us. I highly recommend Saad for his potential clients. A+++ <br>
            Thank you, Saad, I wish you all the best."
          </p>
          <footer class="text-xs text-foreground/50">
            — Arni Gali, pulsetto.tech
          </footer>
        </blockquote>

        <blockquote class="rounded-lg border border-foreground/10 bg-foreground/[0.03] p-4 text-sm">
          <p class="mb-3 text-foreground/80">
            "Saad is awesome! He implemented the design we had on our Shopify store and went above and beyond to find right app solutions and making sure they are customized to our specific needs! <br> Highly recommend him and will be hiring him again!"
          </p>
          <footer class="text-xs text-foreground/50">
            — Yasir, Besto Prints
          </footer>
        </blockquote>

      </div>

    </section>

    <Hr />

    <!-- FREE AUDIT OFFER -->
    <section id="free-audit" class="pt-12 pb-6">

      <h2 class="mb-2 text-2xl font-semibold tracking-wide">
        Free Shopify Store Audit
      </h2>

      <p class="mb-4 max-w-2xl text-sm">
        Not sure why your store isn't converting? I'll review it and send you a short,
        actionable report with the exact UX issues and quick wins holding back your sales, no strings attached.
      </p>

      <ul class="mb-6 space-y-2 max-w-2xl text-sm">
        <li>✓ Product page & cart UX review</li>
        <li>✓ Top 3 fixes to increase conversions</li>
        <li>✓ Delivered via WhatsApp or email within 48 hours</li>
      </ul>

      <a
        href="https://wa.me/+923314002075?text=Hi Saad, I'd like a free Shopify store audit"
        target="_blank"
        rel="noopener"
        class="inline-block rounded bg-green-600 px-6 py-3 text-center text-sm font-medium text-white transition hover:bg-green-700"
      >
        Request Your Free Audit
      </a>

    </section>

    <Hr />

    <!-- APP-FREE AUDIT -->
    <section id="app-free-audit" class="pt-12 pb-6">

      <h2 class="mb-2 text-2xl font-semibold tracking-wide">
        The App-Free Audit: Features You Can Build in Your Theme Natively Without Relying on the App
      </h2>

      <p class="mb-4 max-w-2xl text-sm">
        Most Shopify stores are paying $20-$50/month on apps that can be replaced with
        a few lines of custom Liquid code. I'll audit your app stack and tell you exactly
        which ones are slowing your store down and costing you money unnecessarily.
      </p>

      <ul class="mb-6 space-y-2 max-w-2xl text-sm">
        <li>✓ Full review of your installed apps</li>
        <li>✓ Identify apps you can remove and replace with custom code</li>
        <li>✓ Estimated monthly savings & page speed impact for each</li>
        <li>✓ Delivered via WhatsApp or email within 48 hours, free, no strings attached</li>
      </ul>

      <p class="mb-6 max-w-2xl text-sm text-accent font-medium">
        Common culprits: bundle builders, basic upsells, sticky add-to-cart bars.
      </p>

      <a
        href="https://wa.me/+923314002075?text=Hi Saad, I'd like the App-Free Audit for my Shopify store"
        target="_blank"
        rel="noopener"
        class="inline-block rounded bg-green-600 px-6 py-3 text-center text-sm font-medium text-white transition hover:bg-green-700"
      >
        Get My App-Free Audit
      </a>

    </section>

    <Hr />

    <!-- TECHNICAL RETAINER -->
    <section id="retainer" class="pt-12 pb-6">

      <h2 class="mb-2 text-2xl font-semibold tracking-wide">
        Technical Retainer for Small Shopify Store Owners
      </h2>

      <p class="mb-4 max-w-2xl text-sm">
        Constantly running into small technical issues, tweaks, or feature requests?
        Instead of hiring an agency or paying per-project rates, get a dedicated Shopify
        developer on retainer, available every month, ready when you need me.
      </p>

      <ul class="mb-4 space-y-2 max-w-2xl text-sm">
        <li>✓ Up to <strong>8 hours/month</strong> of Shopify development work</li>
        <li>✓ Theme fixes, custom tweaks, section edits, app integrations</li>
        <li>✓ Priority WhatsApp access, no ticket system, no agency delays</li>
        <li>✓ Monthly report of work done & suggestions for the next month</li>
        <li>✓ Cancel anytime, no long-term contracts</li>
      </ul>

      <!-- TODO: Replace $XXX with your actual starting price -->
      <p class="mb-2 max-w-2xl text-sm text-foreground/70">
        Starting from <strong>$240/month</strong>
      </p>

      <p class="mb-2 max-w-2xl text-sm text-accent font-medium">
        Best for stores doing $5k-$50k/month that need a reliable developer without full-time costs.
      </p>

      <p class="mb-6 max-w-2xl text-sm text-foreground/50">
        Not for enterprise stores or one-time projects.
      </p>

      <div class="flex flex-col gap-4 sm:flex-row">
        <a
          href="https://wa.me/+923314002075?text=Hi Saad, I'm interested in the Technical Retainer for my Shopify store"
          target="_blank"
          rel="noopener"
          class="inline-block rounded bg-green-600 px-6 py-3 text-center text-sm font-medium text-white transition hover:bg-green-700"
        >
          Inquire on WhatsApp
        </a>

        <a
          href="https://calendly.com/saadgfx97/shopify-theme-development"
          target="_blank"
          rel="noopener"
          class="inline-block rounded border border-muted px-6 py-3 text-center text-sm font-medium text-white transition hover:border-white"
        >
          Book a Free 15-min Call
        </a>
      </div>

    </section>

    <Hr />

    <!-- FAQ -->
    <section id="faq" class="pt-12 pb-6">

      <h2 class="mb-6 text-2xl font-semibold tracking-wide">
        Common Questions
      </h2>

      <dl class="max-w-2xl space-y-6 text-sm">

        <div>
          <dt class="font-semibold mb-1">I'm not technical, will I understand your reports?</dt>
          <dd class="text-foreground/70">Yes. I write everything in plain English with clear before/after explanations. No jargon, no walls of code.</dd>
        </div>

        <div>
          <dt class="font-semibold mb-1">How quickly can you get started?</dt>
          <dd class="text-foreground/70">Usually within 1-3 days. Message me on WhatsApp and I'll tell you my current availability upfront.</dd>
        </div>

        <div>
          <dt class="font-semibold mb-1">What if I only need help once in a while?</dt>
          <dd class="text-foreground/70">The retainer is cancel-anytime, no contracts. If you only need a one-off fix, message me and we can do a single project instead.</dd>
        </div>

        <div>
          <dt class="font-semibold mb-1">What timezone are you in?</dt>
          <dd class="text-foreground/70">I'm based in Pakistan (PKT, UTC+5). I work with store owners across the US, UK, and Europe with no issues, I reply same day during business hours.</dd>
        </div>

      </dl>

    </section>

    <Hr />

    <!-- BLOG CONTENT -->

    {
      featuredPosts.length > 0 && (
        <>
          <section id="featured" class="pt-12 pb-6">
            <h2 class="text-2xl font-semibold tracking-wide">
              Featured Shopify Development Articles
            </h2>

            <ul>
              {featuredPosts.map(data => (
                <Card variant="h3" {...data} />
              ))}
            </ul>
          </section>

          {recentPosts.length > 0 && <Hr />}
        </>
      )
    }

    {
      recentPosts.length > 0 && (
        <section id="recent-posts" class="pt-12 pb-6">

          <h2 class="text-2xl font-semibold tracking-wide">
            Latest Shopify Development Insights
          </h2>

          <ul>
            {recentPosts.map(
              (data, index) =>
                index < SITE.postPerIndex && <Card variant="h3" {...data} />
            )}
          </ul>

        </section>
      )
    }

    <div class="my-8 text-center">
      <LinkButton href="/posts/">
        All Articles
        <IconArrowRight class="inline-block rtl:-rotate-180" />
      </LinkButton>
    </div>

  </main>

  <Footer />
</Layout>

<script>
  document.addEventListener("astro:page-load", () => {
    const indexLayout = (document.querySelector("#main-content") as HTMLElement)
      ?.dataset?.layout;

    if (indexLayout) {
      sessionStorage.setItem("backUrl", "/");
    }
  });
</script>
